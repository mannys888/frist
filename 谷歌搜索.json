{
  "sources": [
    {
      "name": "🎵 音乐搜索",
      "url": "https://itunes.apple.com/search?term={wd}&limit=30&entity=song",
      "parseConfig": {
        "type": "json",
        "jsonPath": "results",
        "titleField": "trackName",
        "urlField": "previewUrl"
      }
    },
    {
      "name": "📺 直播源",
      "url": "https://raw.githubusercontent.com/mannys888/frist/refs/heads/main/迦南诗歌.txt",
      "parseConfig": { "type": "txt", "line_sep": "," }
    }
  ],
  "searchEngines": [
    {
      "name": "需要Cookie的引擎",
      "url": "https://example.com/api/search?q={wd}",
      "headers": {
        "User-Agent": "Mozilla/5.0",
        "Authorization": "Bearer your_token_here"
      },
      "cookie": "sessionid=abc123; token=xyz789",
      "parse": {
        "type": "json",
        "path": "data.list",
        "title": "name",
        "url": "play_url",
        "pic": "cover"
      },
      "resolve": false
    },
    {
      "name": "iTunes 音乐",
      "url": "https://itunes.apple.com/search?term={wd}&limit=30&entity=song",
      "parse": {
        "type": "json",
        "path": "results",
        "title": "trackName",
        "artist": "artistName",
        "url": "previewUrl",
        "pic": "artworkUrl100"
      },
      "resolve": false
    }
  ],
  "global": {
    "debug": true,
    "defaultTimeout": 15000
  }
}