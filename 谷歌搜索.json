    "Cookie": "kw_token=5T9P3B"
  },
  "parse": {
    "path": "data.list",
    "title": "name",
    "artist": "artist",
    "url": "rid",
    "pic": "pic"
  },
  "urlTemplate": "http://antiserver.kuwo.cn/anti.s?format=mp3&rid={url}&type=convert_url",
  "resolve": false
},
    {
    "name": "🎵 网易云音乐",
    "url": "http://music.163.com/api/search/get/web?s={wd}&type=1&limit=20",
    "headers": {"User-Agent": "Mozilla/5.0"},
    "parse": {
        "path": "result.songs",
        "title": "name",
        "artist": "artists.0.name",
        "url": "id",
        "pic": "album.picUrl"
    },
    "urlTemplate": "https://music.163.com/song/media/outer/url?id={url}.mp3",
    "resolve": false
   }
  ],
  "global": {
    "debug": true,
    "defaultTimeout": 15000
  }
