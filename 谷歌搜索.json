
  "sources": [
    {
      "name": "央视栏目",
      "handler": "h_oaiacv",
      "detailHandler": "d_23xrtc",
      "playHandler": "p_rww3e5"
    }
  ],
  "customHandlers": {
    "d_23xrtc": "function(ctx) {\n    var parts = ctx.vodId.split(\"###\");\n    if (parts.length < 4) {\n      console.log(\"详情: 复合ID格式错误\");\n      return { list: [] };\n    }\n    var columnId = parts[0];\n    var title = parts[1];\n    var lastVideoGuid = parts[2];\n    var logo = parts[3];\n    \n    if (lastVideoGuid === \"_\" || lastVideoGuid === \"\") {\n      console.log(\"详情: 该栏目暂无最新视频\");\n      return { list: [] };\n    }\n    \n    var infoUrl = \"https://api.cntv.cn/video/videoinfoByGuid?guid=\" + lastVideoGuid + \"&serviceId=tvcctv\";\n    var infoResp = req(infoUrl);\n    var infoJson;\n    try {\n      infoJson = JSON.parse(infoResp.content);\n    } catch(e) {\n      console.log(\"详情: 视频信息解析失败\");\n      return { list: [] };\n    }\n    if (!infoJson.ctid) {\n      console.log(\"详情: 未找到 ctid\");\n      return { list: [] };\n    }\n    var topicId = infoJson.ctid;\n    var channel = infoJson.channel || \"\";\n    \n    var listUrl = \"https://api.cntv.cn/NewVideo/getVideoListByColumn?id=\" + topicId + \"&d=&p=1&n=100&sort=desc&mode=0&serviceId=tvcctv&t=json\";\n    var listResp = req(listUrl);\n    var listJson;\n    try {\n      listJson = JSON.parse(listResp.content);\n    } catch(e) {\n      console.log(\"详情: 视频列表解析失败\");\n      return { list: [] };\n    }\n    var videos = (listJson.data && listJson.data.list) ? listJson.data.list : [];\n    var playUrls = [];\n    for (var i = 0; i < videos.length; i++) {\n      var video = videos[i];\n      var playId = video.pid || video.vid || video.guid;\n      if (playId) {\n        playUrls.push(video.title + \"$\" + playId);\n      }\n    }\n    if (playUrls.length === 0) {\n      console.log(\"详情: 没有可播放的视频\");\n      return { list: [] };\n    }\n    var vod = {\n      vod_id: ctx.vodId,\n      vod_name: title,\n      vod_pic: logo,\n      type_name: channel,\n      vod_play_from: \"央视\",\n      vod_play_url: playUrls.join(\"#\")\n    };\n    return { list: [vod] };\n  }",
    "p_rww3e5": "function(ctx) {\n    var pid = ctx.id;\n    if (!pid) {\n      console.log(\"播放: 未提供视频ID\");\n      return { parse: 0, playUrl: \"\", url: \"\" };\n    }\n    var url = \"https://vdn.apps.cntv.cn/api/getHttpVideoInfo.do?pid=\" + pid;\n    var resp = req(url);\n    var json;\n    try {\n      json = JSON.parse(resp.content);\n    } catch(e) {\n      console.log(\"播放: 解析播放地址失败\");\n      return { parse: 0, playUrl: \"\", url: \"\" };\n    }\n    var hls = json.hls_url || \"\";\n    return { parse: 0, playUrl: \"\", url: hls };\n  }",
    "h_oaiacv": "function(ctx) {\n    var url = \"https://api.cntv.cn/lanmu/columnSearch?p=1&n=20&serviceId=tvcctv&t=json\";\n    var resp = req(url);\n    var json;\n    try {\n      json = JSON.parse(resp.content);\n    } catch(e) {\n      console.log(\"列表JSON解析失败: \" + e.message);\n      json = {};\n    }\n    var data = json;\ndata = data[\"response\"];\ndata = data[\"docs\"];\n    if (!Array.isArray(data)) data = [];\n    var result = [];\n    for (var i = 0; i < data.length; i++) {\n      var item = data[i];\n      var columnId = item.id || item._id || \"\";\n      var columnName = item[\"column_name\"] || \"无标题\";\n      var lastVideoGuid = \"\";\n      try {\n        if (item.lastVIDE && item.lastVIDE.videoId) lastVideoGuid = item.lastVIDE.videoId;\n      } catch(e) { lastVideoGuid = \"\"; }\n      var logo = item[\"column_logo\"] || \"\";\n      var compositeId = columnId + \"###\" + columnName + \"###\" + (lastVideoGuid || \"_\") + \"###\" + logo;\n      var vod = { vod_id: compositeId, vod_name: columnName, vod_pic: logo };\n      result.push(vod);\n    }\n    return result;\n  }"
  },
  "global": {
    "debug": true,
    "defaultPic": ""
  }
}