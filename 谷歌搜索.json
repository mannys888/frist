{
  "sources": [
    {
      "name": "反📺直播源",
      "url": "https://raw.githubusercontent.com/mannys888/frist/refs/heads/main/迦南诗歌.txt",
      "parseConfig": { "type": "txt", "line_sep": "," }
    }
  ],
  "searchEngines": [
    {
      "name": "🎵 完整歌曲(JioSaavn)",
      "url": "https://jiosaavn-api.vercel.app/search/songs?query={wd}&limit=20",
      "headers": { "User-Agent": "Mozilla/5.0" },
      "parse": {
        "path": "data.results",
        "title": "name",
        "artist": "primaryArtists",
        "url": "downloadUrl.3.link",
        "pic": "image.2.link"
      },
      "resolve": false
    },
    {
      "name": "🎵 试听(iTunes)",
      "url": "https://itunes.apple.com/search?term={wd}&limit=10&entity=musicTrack",
      "parse": {
        "path": "results",
        "title": "trackName",
        "artist": "artistName",
        "url": "previewUrl",
        "pic": "artworkUrl100"
      },
      "resolve": false
    }
  ],
  "global": {
    "debug": true,
    "defaultTimeout": 15000
  }
}