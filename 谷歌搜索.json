{
  "sources": [
     {
      "name": "YouTube 搜索",
      "url": "https://apify.com/portfolio/youtube-search-api?query={wd}",
      "headers": {"User-Agent": "Mozilla/5.0"},
      "parse": {
        "type": "json",
        "path": "items",
        "title": "title",
        "url": "url",
        "pic": "thumbnail"
      },
      "resolve": true
    },
    {
      "name": "📺 直播源",
      "url": "https://raw.githubusercontent.com/mannys888/frist/refs/heads/main/迦南诗歌.txt",
      "parseConfig": { "type": "txt", "line_sep": "," }
    },

    {
      "name": "需要Cookie的引擎",
      "url": "https://example.com/api/search?q={wd}",
      "headers": {
        "User-Agent": "Mozilla/5.0",
        "Authorization": "Bearer your_token_here"
      },
      "cookie": "sessionid=abc123; token=xyz789",
      "parse": {
        "type": "json",
        "path": "data.list",
        "title": "name",
        "url": "play_url",
        "pic": "cover"
      },
      "resolve": false
    },
    {
    "name": "SearXNG 视频1",
    "url": "https://<公共实例地址>/search?q={wd}&categories=videos&format=json",
    "headers": { "User-Agent": "Mozilla/5.0" },
    "parse": {
        "type": "json",
        "path": "results",
        "title": "title",
        "url": "url",
        "pic": "thumbnail_src"
    },
    "resolve": true
},
   {
    "name": "SearXNG 视频2",
    "url": "https://your-searxng-instance.com/search?q={wd}&categories=videos&format=json",
    "headers": {"User-Agent": "Mozilla/5.0"},
    "parse": {
      "type": "json",
      "path": "results",
      "title": "title",
      "url": "url",
      "pic": "thumbnail_src"
    },
    "resolve": true
  }
  ],
  "global": {
    "debug": true,
    "defaultTimeout": 15000
  }
} 



