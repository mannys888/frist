{
  "sources": [
    {
      "name": "📺 直播源",
      "url": "https://raw.githubusercontent.com/mannys888/frist/refs/heads/main/迦南诗歌.txt",
      "parseConfig": { "type": "txt", "line_sep": "," }
    },
    {
      "name": "🎵 音乐搜索（键盘输入）",
      "url": "https://itunes.apple.com/search?term={wd}&limit=30&entity=song",
      "parseConfig": { "type": "json", "jsonPath": "results", "titleField": "trackName", "urlField": "previewUrl" }
    }
  ],
  "searchEngines": [
    {
      "name": "SearXNG 视频",
      "url": "https://searx.be/search?q={wd}&categories=videos&format=json",
      "headers": { "User-Agent": "Mozilla/5.0" },
      "parse": { "path": "results", "title": "title", "url": "url", "pic": "thumbnail_src" },
      "resolve": true
    }
  ],
  "global": {
    "debug": true,
    "defaultTimeout": 15000
  }
}